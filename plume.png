package com.app.kavyakanaja

import androidx.compose.ui.graphics.Color

data class KavyaTheme(
    val background: Color = Color(0xFFF5EDE0),
    val surface: Color = Color(0xFFFFFDF7),
    val accent: Color = Color(0xFF8B4513),
    val textPrimary: Color = Color(0xFF2D1A06),
    val textSecondary: Color = Color(0xFF907050),
    val border: Color = Color(0xFFD4B896)
)

val LightKavyaTheme = KavyaTheme()

val DarkKavyaTheme = KavyaTheme(
    background = Color(0xFF1C120A),
    surface = Color(0xFF2A1C0E),
    accent = Color(0xFFC8A050),
    textPrimary = Color(0xFFF5E6C8),
    textSecondary = Color(0xFF907050),
    border = Color(0xFF3D2A0E)
)